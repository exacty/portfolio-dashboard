# Copy to .env.local and fill in values

# Market data cache (SQLite market_data_cache; scripts/market_data_fetch.py)
# MARKET_CACHE_HISTORY_TTL_SEC=14400
# MARKET_CACHE_EARNINGS_TTL_SEC=86400
# MARKET_CACHE_DIVIDENDS_TTL_SEC=86400

# Optional: second dividend source for cross-check (Financial Modeling Prep). Without key: only yfinance.
# FMP_API_KEY=

# Max rows in portfolio_snapshots (0 = unlimited). Oldest rows deleted after each save.
# PORTFOLIO_SNAPSHOT_MAX_ROWS=500

# After refresh_portfolio: warm market_data_cache (history+earnings) per ticker (slower, faster UI modals).
# WARM_MARKET_CACHE_AFTER_REFRESH=1
# WARM_MAX_TICKERS=50
# WARM_MAX_TICKERS=0   # all tickers
# WARM_HISTORY_RANGE=1y

# Postgres (optional; Phase 1A foundation, no behavior change until routes switch)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# IBKR Flex Web Service (for portfolio sync)
IBKR_FLEX_TOKEN=your_token_here
IBKR_FLEX_QUERY_ID=your_query_id_here
